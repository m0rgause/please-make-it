NODE_ENV=development
PORT=3000
BASE_URL=http://localhost:3000
TARGET_URL=https://komiku.org
LOG_LEVEL=debug
CORS_ORIGINS=*
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW=60000

# PostgreSQL
DATABASE_URL=postgresql://user:password@localhost:5432/diary

# TG-S3 / S3-compatible image storage
STORAGE_ENDPOINT=https://your-worker.your-subdomain.workers.dev
STORAGE_BUCKET=your-bucket-name
STORAGE_ACCESS_KEY=your-access-key
STORAGE_SECRET_KEY=your-secret-key
STORAGE_PUBLIC_URL=https://your-public-url.example.com

# Ingestion API key (protect /api/ingest/* routes)
INGEST_API_KEY=change-me-to-a-long-random-secret
